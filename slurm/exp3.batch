#!/bin/bash
#SBATCH --job-name=soccer_ma_exp3
#SBATCH --output=logs/exp3_%j.out
#SBATCH --error=logs/exp3_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --gres=gpu:1
#SBATCH --mem=32G
#SBATCH --time=03:00:00
#SBATCH --partition=ice-gpu

cd $SLURM_SUBMIT_DIR
source activate soccertwos
export RAY_TMPDIR=$SCRATCH/ray_tmp
mkdir -p $RAY_TMPDIR logs
cd training
python train_adaptive_ttg.py
